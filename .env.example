# Shared-dots storage — a Redis-compatible KV store (e.g. Upstash, or Vercel Marketplace).
# Copy this file to .env.local and fill in the two values from your database's REST API.
# The app reads these automatically via @vercel/kv.
#
# The app runs without them — you just won't see other participants' shared dots.
KV_REST_API_URL=your_kv_rest_url_here
KV_REST_API_TOKEN=your_kv_rest_token_here
